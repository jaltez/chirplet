APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# Choose your LLM provider: "hermes" (OpenAI-compatible API) or "ollama" (local)
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=512

# --- Hermes (OpenAI-compatible) ---
# If your Hermes endpoint already ends with /v1, keep it as-is.
HERMES_BASE_URL=http://127.0.0.1:8001/v1
HERMES_API_KEY=
HERMES_MODEL=deepseek-chat
HERMES_TIMEOUT_SECONDS=45
# Set to json_object only if your Hermes deployment supports OpenAI response_format.
HERMES_RESPONSE_FORMAT=none

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=60

# --- Session ---
# Turn history kept in the local backend before sending to the provider.
ENABLE_SESSION_MEMORY=true
SESSION_TURN_LIMIT=8
SESSION_TTL_MINUTES=60
SESSION_CLEANUP_INTERVAL_SECONDS=300

# --- Database ---
DATABASE_PATH=data/chirplet.db

# --- CORS ---
# Comma-separated list of allowed origins. Use "*" for development only.
CORS_ORIGINS=*

# --- Security (optional) ---
# Set AUTH_TOKEN to require Bearer token auth on all /api/* endpoints.
# Leave empty for local-only deployments (default).
AUTH_TOKEN=
# Max requests per minute per IP (0 = disabled, default).
RATE_LIMIT_PER_MINUTE=0

# --- Prompting ---
# Override the assistant persona (appended to the system prompt).
CHIRPLET_PERSONA=
# Inject current date/time into the system prompt (default: true).
ENABLE_TIME_CONTEXT=true
