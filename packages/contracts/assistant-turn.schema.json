{
  "$defs": {
    "AssistantPayload": {
      "properties": {
        "text": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Text",
          "type": "string"
        },
        "expression": {
          "$ref": "#/$defs/AvatarExpression"
        },
        "action": {
          "default": "idle",
          "maxLength": 40,
          "title": "Action",
          "type": "string"
        },
        "voice_locale": {
          "default": "es-ES",
          "maxLength": 16,
          "title": "Voice Locale",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "AssistantPayload",
      "type": "object"
    },
    "AvatarExpression": {
      "properties": {
        "state": {
          "$ref": "#/$defs/AvatarState",
          "default": "speaking"
        },
        "mood": {
          "$ref": "#/$defs/AvatarMood",
          "default": "friendly"
        },
        "mouth": {
          "$ref": "#/$defs/MouthCue",
          "default": "smile"
        }
      },
      "title": "AvatarExpression",
      "type": "object"
    },
    "AvatarMood": {
      "enum": [
        "neutral",
        "friendly",
        "curious",
        "calm",
        "cheerful",
        "concerned"
      ],
      "title": "AvatarMood",
      "type": "string"
    },
    "AvatarState": {
      "enum": [
        "idle",
        "listening",
        "thinking",
        "speaking",
        "error",
        "disconnected"
      ],
      "title": "AvatarState",
      "type": "string"
    },
    "MouthCue": {
      "enum": [
        "closed",
        "open",
        "smile",
        "round"
      ],
      "title": "MouthCue",
      "type": "string"
    },
    "ResponseMeta": {
      "properties": {
        "provider": {
          "default": "hermes",
          "title": "Provider",
          "type": "string"
        },
        "fallback_used": {
          "default": false,
          "title": "Fallback Used",
          "type": "boolean"
        },
        "issue": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Issue"
        }
      },
      "title": "ResponseMeta",
      "type": "object"
    },
    "TimingMetrics": {
      "properties": {
        "request_started_at": {
          "title": "Request Started At",
          "type": "string"
        },
        "completed_at": {
          "title": "Completed At",
          "type": "string"
        },
        "duration_ms": {
          "minimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        }
      },
      "required": [
        "request_started_at",
        "completed_at",
        "duration_ms"
      ],
      "title": "TimingMetrics",
      "type": "object"
    }
  },
  "properties": {
    "session_id": {
      "title": "Session Id",
      "type": "string"
    },
    "assistant": {
      "$ref": "#/$defs/AssistantPayload"
    },
    "timing": {
      "$ref": "#/$defs/TimingMetrics"
    },
    "meta": {
      "$ref": "#/$defs/ResponseMeta"
    }
  },
  "required": [
    "session_id",
    "assistant",
    "timing"
  ],
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chirplet.local/contracts/assistant-turn.schema.json",
  "title": "AssistantTurnResponse"
}
